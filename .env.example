# viewlyt — copie para `.env` e preencha. Carregado automaticamente pelo `vl`
# (só stdlib; valores já exportados no ambiente têm prioridade e não são sobrescritos).
# NUNCA commite o `.env` real — só este exemplo é versionado.

# --- LLM (vl live / vl ask) ---
# Chave do provedor. Usada como fallback de --api-key no `vl live` e pelo `vl ask`.
OPENROUTER_API_KEY=sk-or-...
# Também aceito como alias de chave por --api-key.
# LLM_API_KEY=

# Modelo padrão (qualquer id do OpenRouter).
LLM_NAME=google/gemini-2.5-flash
# Modelo barato só para a extração de entidades do `vl ask --persist`.
# LLM_EXTRACT_NAME=

# --- vl ask --persist (RAG opcional) ---
# EMBEDDING_NAME=intfloat/multilingual-e5-large
# EMBEDDING_PROVIDER=fastembed
# RAG_TTL_DAYS=15
# RAG_CHUNK_TOKENS=1200

# --- Scraper (opcional) ---
# Aponta para um binário Chrome/Chromium específico (ex.: Brave).
# VIEWLYT_CHROME_BINARY=/usr/bin/google-chrome
